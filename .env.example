# weather-ops 환경변수 — 이 파일을 복사해서 .env 로 저장하세요.
# 키가 없는 출처는 자동으로 "키 필요"로 표시되며, 앱은 Open-Meteo(무키)만으로도 동작합니다.

# 서버 포트 (기본 8787)
PORT=8787

# 세션 서명 비밀키 (팀 로그인용). 운영에서는 반드시 임의의 긴 문자열로 설정.
SESSION_SECRET=

# 팀 위치 공유 데이터 저장 파일 경로 (기본: weather-ops/data.json)
# WX_DB_PATH=

# ── 기상청 단기예보 (공공데이터포털 data.go.kr 에서 무료 발급) ──
# https://www.data.go.kr/data/15084084/openapi.do 활용신청 후 "일반 인증키(Decoding)" 사용
KMA_SERVICE_KEY=

# ── 기상청 METAR 공항 실측 (KMA API허브 apihub.kma.go.kr 의 authKey) ──
# 단기예보가 못 주는 가시거리·운고·돌풍을 가장 가까운 공항(ICAO) 실측으로 보완.
# https://apihub.kma.go.kr 가입 후 발급한 authKey 를 넣으세요.
KMA_METAR_KEY=
# ⚠️ apihub는 API별 "활용신청"이 필요합니다. METAR(AmmIwxxmService) 활용신청 후 사용하세요.
# (선택) 엔드포인트 URL 직접 지정. {icao}/{key} 치환됨. 미설정 시 아래 기본값 사용.
# 기본값은 AmmIwxxmService/getMetar 의 <msgText>(원문 METAR)를 파싱합니다.
# KMA_METAR_URL=https://apihub.kma.go.kr/api/typ02/openApi/AmmIwxxmService/getMetar?pageNo=1&numOfRows=10&dataType=XML&icao={icao}&authKey={key}


# ── OpenWeatherMap (무료 키, 한국 커버) ──
# https://openweathermap.org/api 가입 후 발급
OWM_KEY=

# ── Apple WeatherKit REST (Apple Developer 계정 필요) ──
# Team ID / Key ID / Service(App) ID 와 .p8 비공개키 내용
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_SERVICE_ID=
# .p8 파일 내용 전체. 줄바꿈은 \n 으로 치환해서 한 줄로 넣거나, 따옴표로 감싼 멀티라인 사용
APPLE_PRIVATE_KEY=

# ── 네이버 날씨 ──
# 공식 API가 없어 weather.naver.com 을 크롤링합니다. 키는 필요 없지만
# 사이트 구조 변경 시 깨질 수 있고, 약관상 회색지대임에 유의하세요.
# 끄려면 0 으로 설정
NAVER_CRAWL_ENABLED=1

# ── 사용량 통계 (/api/stats) ──
# 설정하면 /api/stats 조회 시 ?token=<값> 일치를 요구(공개 노출 방지). 미설정 시 누구나 조회.
STATS_TOKEN=
# (선택) 로그 파일 경로. 기본: weather-ops/metrics.log
# METRICS_LOG=

# ── 외부 저장: Notion (선택) ──
# 사용 로그를 Notion 데이터베이스에 남긴다(재시작에도 보존).
# 1) https://www.notion.so/my-integrations 에서 내부 통합 생성 → 토큰(secret_...)
# 2) 대상 DB 페이지 → ⋯ → 연결(Connections) 에 그 통합 추가
# 3) 아래 두 값 설정
NOTION_TOKEN=
NOTION_LOG_DB=9ad4524bef3f44c090c2bb99b3272fe5

# ── 케이웨더 (다음) API (선택) ──
# api.kweather.co.kr 가입 후 발급. 무료는 비상업용 5,000콜/일, 상업용은 유료.
KWEATHER_KEY=
